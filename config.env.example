# Matrix Stack Configuration Template
# Reference-only file: setup.sh and update.sh do not source config.env automatically.
# Use this as a checklist, then apply values to the real config files and setup.sh.

# ── Domain & Network ──────────────────────────────────────────────
# The domain your Matrix homeserver will be accessible at
YOUR_DOMAIN=example.com

# Your server's public IPv4 address
YOUR_IPV4=1.2.3.4

# Your server's public IPv6 address (optional)
YOUR_IPV6=2001:db8::1

# Email for Let's Encrypt certificate renewal notifications
YOUR_EMAIL=admin@example.com

# ── Installation ──────────────────────────────────────────────────
# Directory where Matrix stack will be installed
MATRIX_DIR=/opt/matrix

# ── Secrets ───────────────────────────────────────────────────────
# The following secrets are auto-generated by setup.sh
# You do NOT need to set them manually — setup.sh will create them:
#
# - TURN_SHARED_SECRET (64 hex chars) — shared with Coturn
# - REGISTRATION_TOKEN (64 hex chars) — required for user signup
# - LIVEKIT_API_KEY (e.g., "API123abc") — LiveKit credentials
# - LIVEKIT_API_SECRET (64 hex chars) — LiveKit login secret
#
# These will be saved to:
#   - $MATRIX_DIR/turn_shared_secret
#   - $MATRIX_DIR/registration_token
#   - $MATRIX_DIR/livekit_api_key
#   - $MATRIX_DIR/livekit_api_secret
#
# The files are restricted to 600 permissions (owner read/write only)

# ── Optional: Override defaults (normally not needed) ──────────────
# SSH port (if not standard 22)
# SSH_PORT=22

# Deployed with Ansible? Set to yes to skip these defaults
# ANSIBLE_DEPLOYMENT=no
